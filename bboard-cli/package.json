{
  "name": "@midnight-ntwrk/bboard-cli",
  "version": "0.1.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -R ../contract/src/managed dist/contract/src/managed",
    "ci": "npm run typecheck && npm run lint && npm run build",
    "lint": "eslint src",
    "prepack": "npm run build",
    "standalone": "node --max-old-space-size=4096 --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/standalone.ts",
    "preview-remote": "node --max-old-space-size=4096 --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preview.ts",
    "preprod-remote": "node --max-old-space-size=4096 --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preprod.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.1.1"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
